import ghpythonlib.treehelpers as th

def flatten_splitlines(data):
    result = []
    if isinstance(data, list):
        for item in data:
            if isinstance(item, list):
                result.extend(flatten_splitlines(item))
            elif isinstance(item, str):
                result.extend(item.splitlines())
            else:
                result.extend(str(item).splitlines())
    else:
        if isinstance(data, str):
            result.extend(data.splitlines())
        else:
            result.extend(str(data).splitlines())
    return result

